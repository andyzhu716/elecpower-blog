baseURL = 'https://www.elecpower.cn/'
languageCode = 'en-US'
defaultContentLanguage = 'en'
defaultContentLanguageInSubdir = false
title = 'ElecPower - Industrial Power Equipment Solutions'
theme = 'hugo-geekdoc'
enableRobotsTXT = true

# Sitemap configuration
[sitemap]
  changefreq = 'weekly'
  filename = 'sitemap.xml'
  priority = 0.5

# Permalinks
[permalinks]
  blog = '/blog/:year/:month/:slug/'

# Taxonomies
[taxonomies]
  category = 'categories'
  tag = 'tags'

[languages]
  [languages.en]
    languageName = 'English'
    weight = 1
    title = 'ElecPower - Industrial Power Equipment Solutions'
    languageDirection = 'ltr'

  [languages.zh-cn]
    languageName = '中文'
    weight = 2
    title = 'ElecPower - 工业电力设备解决方案'
    languageDirection = 'ltr'

[params]
  geekdocLogo = ''
  geekdocNav = true
  geekdocSearch = true
  geekdocRepo = ''
  geekdocEditPath = ''
  geekdocCustomCSS = 'css/custom.css'

  # SEO params
  description = 'Technical articles about busbar systems, IPB, transformers, and power distribution equipment for engineers and industry professionals.'
  keywords = ['busbar', 'IPB', 'isolated phase bus', 'power transformer', 'electrical equipment', 'industrial power']

[author]
  name = 'ElecPower Team'
  email = 'andyzhu716@gmail.com'